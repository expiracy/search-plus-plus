{
  "name": "search-plus-plus",
  "displayName": "search++",
  "description": "Blazingly fast unified search for files, folders, text, symbols and commands. Supports fuzzy matching, regex, match case, match word, exclude gitignored files. Double-shift to open, tab and shift-tab to cycle between pages, arrow keys to navigate search results. Inspired by JetBrains IDEs",
  "version": "2.0.0",
  "publisher": "expiracy",
  "repository": {
    "type": "git",
    "url": "https://github.com/expiracy/search-plus-plus"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "search",
    "find",
    "file search",
    "text search",
    "symbol search",
    "fuzzy search",
    "regex",
    "go to file",
    "navigate",
    "jetbrains",
    "intellij",
    "search everywhere",
    "quick open",
    "ripgrep",
    "double shift",
    "finder",
    "grep",
    "file finder",
    "search in files",
    "find in files",
    "go to symbol",
    "file explorer",
    "workspace search",
    "content search",
    "code search",
    "filter",
    "lookup",
    "open file",
    "webstorm",
    "pycharm",
    "command palette",
    "command search",
    "actions"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "searchPlusPlus.open",
        "title": "search++: Open Search"
      },
      {
        "command": "searchPlusPlus.openFiles",
        "title": "search++: Search Files"
      },
      {
        "command": "searchPlusPlus.openText",
        "title": "search++: Search Text"
      },
      {
        "command": "searchPlusPlus.openSymbols",
        "title": "search++: Search Symbols"
      },
      {
        "command": "searchPlusPlus.openCommands",
        "title": "search++: Search Commands"
      },
      {
        "command": "searchPlusPlus.reindex",
        "title": "search++: Reindex Workspace"
      },
      {
        "command": "searchPlusPlus.toggleCaseSensitive",
        "title": "search++: Toggle Case Sensitive"
      },
      {
        "command": "searchPlusPlus.toggleRegex",
        "title": "search++: Toggle Regex"
      },
      {
        "command": "searchPlusPlus.toggleGitIgnore",
        "title": "search++: Toggle Only Git Trackable"
      },
      {
        "command": "searchPlusPlus.toggleSearchIgnore",
        "title": "search++: Toggle Exclude Search Ignored"
      },
      {
        "command": "searchPlusPlus.toggleFuzzySearch",
        "title": "search++: Toggle Fuzzy Search"
      },
      {
        "command": "searchPlusPlus.toggleMatchWholeWord",
        "title": "search++: Toggle Match Whole Word"
      },
      {
        "command": "searchPlusPlus.nextTab",
        "title": "search++: Next Tab"
      },
      {
        "command": "searchPlusPlus.prevTab",
        "title": "search++: Previous Tab"
      },
      {
        "command": "searchPlusPlus.autofillPath",
        "title": "search++: Autofill File Path"
      }
    ],
    "keybindings": [
      {
        "command": "searchPlusPlus.open",
        "key": "shift shift",
        "mac": "shift shift"
      },
      {
        "command": "searchPlusPlus.toggleCaseSensitive",
        "key": "alt+c",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.toggleRegex",
        "key": "alt+r",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.toggleGitIgnore",
        "key": "alt+g",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.toggleSearchIgnore",
        "key": "alt+s",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.toggleFuzzySearch",
        "key": "alt+f",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.toggleMatchWholeWord",
        "key": "alt+w",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.nextTab",
        "key": "tab",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.prevTab",
        "key": "shift+tab",
        "when": "searchPlusPlusModalOpen"
      },
      {
        "command": "searchPlusPlus.autofillPath",
        "key": "right",
        "when": "searchPlusPlusModalOpen && searchPlusPlusFileTab"
      }
    ],
    "configuration": [
      {
        "title": "General",
        "properties": {
          "searchPlusPlus.excludeGitIgnored": {
            "order": 1,
            "type": "boolean",
            "default": true,
            "description": "Exclude git-ignored files and folders from search results by default"
          },
          "searchPlusPlus.excludeSearchIgnored": {
            "order": 2,
            "type": "boolean",
            "default": true,
            "description": "Exclude files matching .searchignore patterns from search results by default"
          },
          "searchPlusPlus.excludePaths": {
            "order": 3,
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Glob patterns to always exclude from search results (e.g., \"**/dist/**\", \"**/*.min.js\"). Applied in addition to gitignore."
          },
          "searchPlusPlus.maxResults": {
            "order": 4,
            "type": "number",
            "default": 200,
            "description": "Maximum number of results to display per search mode"
          },
          "searchPlusPlus.debounceMs": {
            "order": 5,
            "type": "number",
            "default": 100,
            "description": "Debounce delay in milliseconds before triggering search"
          }
        }
      },
      {
        "title": "Everything Tab",
        "properties": {
          "searchPlusPlus.everywhere.sections": {
            "order": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "files",
                "folders",
                "text",
                "symbols",
                "commands"
              ]
            },
            "uniqueItems": true,
            "default": [
              "files",
              "folders",
              "text",
              "symbols",
              "commands"
            ],
            "markdownDescription": "Sections shown on the Everything tab. Array order controls display order. Remove a section to hide it."
          },
          "searchPlusPlus.everywhere.resultLimit": {
            "order": 2,
            "type": "integer",
            "default": 20,
            "minimum": 1,
            "maximum": 200,
            "description": "Maximum results shown per section on the Everything tab"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "package": "npx @vscode/vsce package",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.4.0",
    "vitest": "^3.1.1"
  },
  "lint-staged": {
    "*.ts": "eslint"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.15.9",
    "fzf": "^0.5.2",
    "ignore": "^5.3.0"
  }
}
